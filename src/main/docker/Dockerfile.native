####
# Native runtime image for mediawiki-mcp — the deploy artifact.
#
# ubi9-minimal base: its glibc matches the ubi9 Mandrel builder
# (quay.io/quarkus/ubi9-quarkus-mandrel-builder-image:jdk-25). The smaller
# quarkus-micro-image:2.0 is UBI8-based and too old to run a ubi9 binary
# (GLIBC_2.34 not found).
#
# Runtime-only: build the native binary first, then this image wraps it.
#   mvn package -Dnative -Dquarkus.native.container-build=true \
#       -Dquarkus.native.builder-image=quay.io/quarkus/ubi9-quarkus-mandrel-builder-image:jdk-25
#   docker build -f src/main/docker/Dockerfile.native -t mediawiki-mcp .
#
# On the EC2 the container is bound to 127.0.0.1:8081 and fronted by Caddy
# (mcp.howarth.eu/mediawiki/* -> 127.0.0.1:8081). Bot creds injected at run time.
####
FROM registry.access.redhat.com/ubi9/ubi-minimal:9.4
WORKDIR /work/
RUN chown 1001 /work \
    && chmod "g+rwX" /work \
    && chown 1001:root /work
COPY --chown=1001:root target/*-runner /work/application

EXPOSE 8081
USER 1001

ENTRYPOINT ["./application", "-Dquarkus.http.host=0.0.0.0", "-Dquarkus.http.port=8081"]
